# YouTrack Configuration
# Generate a Permanent Token: YouTrack Profile → Authentication → New Token
VITE_YT_URL=https://your-instance.youtrack.cloud
VITE_YT_TOKEN=perm-your-token-here
VITE_YT_PROJECT_ID=0-0

# Optional: Anthropic API key for AI-assisted ticket generation
# Without this, you can still create tickets manually or use Template Generate
VITE_ANTHROPIC_KEY=sk-ant-api03-your-key-here

# Optional: OpenAI API key for usage/balance tracking
# Used by student-reports-ios for Whisper + GPT-4o-mini
VITE_OPENAI_KEY=sk-your-openai-key-here
